<Page x:Class="IISDeployer.View.DynamicDeploymentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1400"
      Title="Configurable Deployment">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== PAGE TITLE ===== -->
            <TextBlock Grid.Row="0" 
                       Text="Configurable Deployment" 
                       FontSize="24" FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <!-- ===== HEADER: Connection Configuration ===== -->
            <GroupBox Grid.Row="1" Header="Connection Configuration" Margin="0,0,0,10" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" HorizontalAlignment="Left" Width="526">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Network Path:" 
                                   VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="NetworkPathTextBox"
                                 Height="25" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Username:" 
                                   VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="UsernameTextBox"
                                 Height="25" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Password:" 
                                   VerticalAlignment="Center" Margin="0,0,10,10" FontWeight="SemiBold"/>
                        <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox Grid.Column="0" x:Name="PasswordBox"
                                         Height="25" VerticalContentAlignment="Center"/>
                            <TextBox Grid.Column="0" x:Name="PasswordTextBox"
                                     Height="25" VerticalContentAlignment="Center" Visibility="Collapsed"/>
                            <Button Grid.Column="1" x:Name="TogglePasswordButton"
                                    Width="30" Height="25" Margin="5,0,0,0"
                                    Click="TogglePasswordButton_Click" ToolTip="Show/Hide Password">
                                <TextBlock x:Name="EyeIcon" Text="👁" FontSize="16"/>
                            </Button>
                        </Grid>
                    </Grid>

                    <Border Grid.Column="2" Background="#FFFFEB3B" CornerRadius="5"
                            Padding="10" BorderBrush="#FFD4AF37" BorderThickness="2">
                        <StackPanel>
                            <TextBlock Text="Saved Configurations" FontWeight="Bold" FontSize="14"
                                       Margin="0,0,0,10" HorizontalAlignment="Center"/>
                            <TextBlock Text="Select Network:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="NetworkConfigComboBox" Height="30"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="NetworkConfigComboBox_SelectionChanged"
                                      ToolTip="Select a saved network configuration"/>
                            <TextBlock Text="Select a configuration to auto-fill credentials" 
                                       FontSize="10" TextWrapping="Wrap" Foreground="#FF666666"
                                       Margin="0,5,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </GroupBox>

            <!-- ===== ACTION SECTION ===== -->
            <GroupBox Grid.Row="2" Header="Action" Margin="0,0,0,10" Padding="10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="Connect" Click="ConnectButton_Click"
                            Width="100" Height="30" Margin="5"/>
                    <Button Content="Disconnect" Click="DisconnectButton_Click"
                            Width="100" Height="30" Margin="5"/>
                    <TextBlock x:Name="StatusTextBlock" Text="Ready..."
                               FontSize="14" Foreground="Blue" Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </GroupBox>

            <!-- ===== SECTION MANAGEMENT ===== -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,6">
                <Button Content="➕ Add Section" Click="AddSectionButton_Click"
                        Width="140" Height="30" Margin="0,0,8,0"
                        Background="#FF1976D2" Foreground="White" FontWeight="SemiBold"
                        ToolTip="Add a new deployment section tab"/>
                <Button Content="🗑 Remove Current Section" Click="RemoveSectionButton_Click"
                        Width="200" Height="30"
                        Background="#FFFBE9E7" Foreground="#FFD32F2F"
                        FontWeight="SemiBold" BorderBrush="#FFEF9A9A"
                        ToolTip="Remove the currently selected section tab"/>
            </StackPanel>

            <!-- ===== DYNAMIC SECTIONS (TabControl) ===== -->
            <TabControl Grid.Row="4" x:Name="SectionsTabControl" MinHeight="600"/>

        </Grid>
    </ScrollViewer>
</Page>
