<UserControl x:Class="IISDeployer.View.Controls.DeploymentSectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="600">

    <UserControl.Resources>
        <Style x:Key="ChecklistItem" TargetType="CheckBox">
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Margin" Value="10,2,0,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="StepLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style x:Key="ProgressLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#FF666666"/>
            <Setter Property="Margin" Value="28,0,0,2"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">

            <!-- Section Title -->
            <TextBlock x:Name="SectionTitleTextBlock" 
                       Text="Deployment Section" 
                       FontSize="16" FontWeight="Bold" Margin="0,0,0,6"/>

            <!-- IIS Website Name -->
            <StackPanel Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="IIS Website Name:" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <ComboBox x:Name="IISWebsiteComboBox"
                              Width="220" Height="26"
                              IsEditable="True"
                              SelectionChanged="IISWebsiteComboBox_SelectionChanged"
                              ToolTip="Select or type the IIS website name. Click 🔄 to load from server."/>
                    <Button Content="🔄" Width="28" Height="26" Margin="4,0,0,0"
                            Click="RefreshWebsitesButton_Click"
                            ToolTip="Load IIS websites from the remote server"/>
                </StackPanel>

                <!-- Start/Stop Website -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Button x:Name="StartWebsiteButton" Content="▶ Start Website"
                            Click="StartWebsiteButton_Click"
                            Width="120" Height="26" Margin="0,0,6,0"
                            Background="#FF388E3C" Foreground="White" FontWeight="SemiBold"
                            ToolTip="Start the IIS website on the remote server"/>
                    <Button x:Name="StopWebsiteButton" Content="⏹ Stop Website"
                            Click="StopWebsiteButton_Click"
                            Width="120" Height="26" Margin="0,0,12,0"
                            Background="#FFD32F2F" Foreground="White" FontWeight="SemiBold"
                            ToolTip="Stop the IIS website on the remote server"/>
                </StackPanel>

                <!-- App Pool Name -->
                <StackPanel Orientation="Horizontal" Margin="0,4,0,6">
                    <TextBlock Text="App Pool Name:" VerticalAlignment="Center"
                               FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <TextBox x:Name="AppPoolNameTextBox"
                             Width="220" Height="26"
                             IsReadOnly="True"
                             Background="#FFF5F5F5"
                             VerticalContentAlignment="Center"
                             ToolTip="Auto-filled from selected IIS website."/>
                </StackPanel>

                <!-- Start/Stop App Pool -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button x:Name="StartAppPoolButton" Content="▶ Start App Pool"
                            Click="StartAppPoolButton_Click"
                            Width="130" Height="26" Margin="0,0,6,0"
                            Background="#FF1976D2" Foreground="White" FontWeight="SemiBold"
                            ToolTip="Start the IIS application pool on the remote server"/>
                    <Button x:Name="StopAppPoolButton" Content="⏹ Stop App Pool"
                            Click="StopAppPoolButton_Click"
                            Width="130" Height="26"
                            Background="#FFE64A19" Foreground="White" FontWeight="SemiBold"
                            ToolTip="Stop the IIS application pool on the remote server"/>
                </StackPanel>
            </StackPanel>

            <!-- STEP 1: Select Files and Folders -->
            <TextBlock Style="{StaticResource StepLabel}" Text="1st Step — Select Files and Folders"/>

            <StackPanel Orientation="Horizontal" Margin="10,4,0,4">
                <TextBlock Text="Parent Source Folder:" VerticalAlignment="Center"
                           FontWeight="SemiBold" Margin="0,0,8,0"/>
                <TextBlock x:Name="ParentSourceFolderLabel" Text="(not set)"
                           VerticalAlignment="Center" Foreground="Gray"
                           TextTrimming="CharacterEllipsis" MaxWidth="350"/>
            </StackPanel>
            <Button Content="Select Parent Folder" Click="SelectParentFolderButton_Click"
                    Width="160" Height="28" HorizontalAlignment="Left" Margin="10,2,0,6"/>

            <StackPanel Orientation="Horizontal" Margin="10,2,0,6">
                <Button Content="Select Files" Click="SelectFilesButton_Click"
                        Width="120" Height="28" Margin="0,0,8,0"/>
                <Button Content="Select Folders" Click="SelectFoldersButton_Click"
                        Width="120" Height="28" Margin="0,0,8,0"/>
                <Button Content="🗑 Clear" Click="ClearSelectedItems_Click"
                        Width="80" Height="28"
                        Background="#FFFBE9E7" Foreground="#FFD32F2F"
                        BorderBrush="#FFEF9A9A" ToolTip="Clear all selected files and folders"/>
            </StackPanel>

            <TextBlock Text="Selected Items:" FontWeight="SemiBold" Margin="10,6,0,2"/>
            <Border BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="4"
                    MinHeight="80" Margin="10,0,0,6" Padding="4">
                <ItemsControl x:Name="SelectedItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#FFE8E8E8" CornerRadius="4" Margin="3" Padding="6,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Icon}" FontSize="14"
                                               Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                               MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                                    <Button Content="✕" Tag="{Binding FullPath}"
                                            Click="RemoveSelectedItem_Click"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="Red" FontWeight="Bold"
                                            Margin="6,0,0,0" Cursor="Hand" ToolTip="Remove"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <Button Content="💾 Save Settings" Click="SaveSettingsButton_Click"
                    Width="140" Height="28" HorizontalAlignment="Left" Margin="10,2,0,10"/>

            <!-- STEP 2: Zip Files -->
            <TextBlock Style="{StaticResource StepLabel}" Text="2nd Step — Zip Files"/>
            <StackPanel Margin="10,0,0,10">
                <CheckBox x:Name="Chk2_CreateDateFolder" Style="{StaticResource ChecklistItem}"
                          Content="Create date subfolder (DDMMYYYY)"/>
                <CheckBox x:Name="Chk2_CopyItems" Style="{StaticResource ChecklistItem}"
                          Content="Copy selected items into staging folder"/>
                <CheckBox x:Name="Chk2_ValidateCopy" Style="{StaticResource ChecklistItem}"
                          Content="Validate copied items exist"/>
                <CheckBox x:Name="Chk2_ZipFolder" Style="{StaticResource ChecklistItem}"
                          Content="Zip staging folder"/>
                <TextBlock x:Name="ZipProgressLabel"
                           Style="{StaticResource ProgressLabel}"
                           Text="" Visibility="Collapsed"/>
                <ProgressBar x:Name="ZipProgressBar" Height="16"
                             Margin="28,2,0,4" Visibility="Collapsed"/>
            </StackPanel>

            <!-- STEP 3: Transfer -->
            <TextBlock Style="{StaticResource StepLabel}" Text="3rd Step — Transfer Zipped File to Remote Server"/>
            <StackPanel Margin="10,0,0,10">
                <CheckBox x:Name="Chk3_TransferZip" Style="{StaticResource ChecklistItem}"
                          Content="Transfer zip to remote destination folder"/>
                <CheckBox x:Name="Chk3_ValidateTransfer" Style="{StaticResource ChecklistItem}"
                          Content="Validate zip exists on remote server"/>
                <CheckBox x:Name="Chk3_UnzipRemote" Style="{StaticResource ChecklistItem}"
                          Content="Unzip transferred file on remote server"/>
                <TextBlock x:Name="UnzipProgressLabel"
                           Style="{StaticResource ProgressLabel}"
                           Text="" Visibility="Collapsed"/>
                <ProgressBar x:Name="UnzipProgressBar" Height="16"
                             Margin="28,2,0,4" Visibility="Collapsed"/>
                <CheckBox x:Name="Chk3_ValidateUnzip" Style="{StaticResource ChecklistItem}"
                          Content="Validate unzipped folder exists"/>
            </StackPanel>

            <!-- STEP 4: Deploy -->
            <TextBlock Style="{StaticResource StepLabel}" Text="4th Step — Stop IIS Website, Deploy, Start"/>
            <StackPanel Margin="10,0,0,10">
                <CheckBox x:Name="Chk4_StopIIS" Content="Stop IIS Website" IsEnabled="False"/>
                <CheckBox x:Name="Chk4_StopAppPool" Content="Stop IIS App Pool" IsEnabled="False"/>
                <CheckBox x:Name="Chk4_BackupEnv" Content="Backup Config File" IsEnabled="False"/>
                <CheckBox x:Name="Chk4_Overwrite" Content="Overwrite Website Contents" IsEnabled="False"/>
                <CheckBox x:Name="Chk4_StartIIS" Content="Start IIS Website" IsEnabled="False"/>
                <CheckBox x:Name="Chk4_StartAppPool" Content="Start IIS App Pool" IsEnabled="False"/>
            </StackPanel>

            <ProgressBar x:Name="MainProgressBar" Height="20"
                         Margin="10,4,0,4" Visibility="Collapsed"/>

            <TextBlock x:Name="SectionStatusTextBlock" Text="Ready..."
                       FontSize="13" Foreground="Blue" TextWrapping="Wrap"
                       Margin="10,2,0,6"/>

            <StackPanel Orientation="Horizontal" Margin="10,4,0,4">
                <Button x:Name="ExecuteButton" Content="▶ Execute Deployment"
                        Click="ExecuteButton_Click"
                        Width="180" Height="35" FontWeight="SemiBold"
                        Background="#FF4CAF50" Foreground="White" Margin="0,0,8,0"/>
                <Button x:Name="CancelButton" Content="✖ Cancel"
                        Click="CancelButton_Click"
                        Width="100" Height="35" FontWeight="SemiBold"
                        Background="#FFF44336" Foreground="White" IsEnabled="False"/>
            </StackPanel>

            <TextBlock x:Name="TimeElapsedTextBlock" Text="Time Elapsed: 00:00"
                       FontSize="13" FontWeight="SemiBold" Foreground="#FF1976D2"
                       Margin="10,4,0,8" Visibility="Collapsed"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
