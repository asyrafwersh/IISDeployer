<Page x:Class="SMBApp.View.SMBPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SMBApp.View"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="800"
      Title="SMBPage">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="SMB Network Connection" 
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- Connection Configuration Section with Split Layout -->
        <GroupBox Grid.Row="1" 
                  Header="Connection Configuration" 
                  Margin="0,0,0,10"
                  Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <!-- Left Side: Manual Input Fields -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Network Path -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Network Path:" 
                               VerticalAlignment="Center" 
                               Margin="0,0,10,10"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             x:Name="NetworkPathTextBox"
                             Height="25"
                             Margin="0,0,0,10"
                             VerticalContentAlignment="Center"
                             Text=""/>

                    <!-- Username -->
                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Username:" 
                               VerticalAlignment="Center" 
                               Margin="0,0,10,10"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             x:Name="UsernameTextBox"
                             Height="25"
                             Margin="0,0,0,10"
                             VerticalContentAlignment="Center"
                             Text=""/>

                    <!-- Password -->
                    <TextBlock Grid.Row="2" Grid.Column="0"
                               Text="Password:" 
                               VerticalAlignment="Center" 
                               Margin="0,0,10,0"
                               FontWeight="SemiBold"/>
                    <Grid Grid.Row="2" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- PasswordBox (visible when password is hidden) -->
                        <PasswordBox Grid.Column="0"
                                     x:Name="PasswordBox"
                                     Height="25"
                                     VerticalContentAlignment="Center"
                                     Password=""/>

                        <!-- TextBox (visible when password is revealed) -->
                        <TextBox Grid.Column="0"
                                 x:Name="PasswordTextBox"
                                 Height="25"
                                 VerticalContentAlignment="Center"
                                 Visibility="Collapsed"/>

                        <!-- Toggle Password Visibility Button -->
                        <Button Grid.Column="1"
                                x:Name="TogglePasswordButton"
                                Width="30"
                                Height="25"
                                Margin="5,0,0,0"
                                Click="TogglePasswordButton_Click"
                                ToolTip="Show/Hide Password">
                            <TextBlock x:Name="EyeIcon" 
                                       Text="👁" 
                                       FontSize="16"/>
                        </Button>
                    </Grid>
                </Grid>

                <!-- Right Side: Saved Configurations Dropdown (Yellow highlighted area) -->
                <Border Grid.Column="2"
                        Background="#FFFFEB3B"
                        CornerRadius="5"
                        Padding="10"
                        BorderBrush="#FFD4AF37"
                        BorderThickness="2">
                    <StackPanel>
                        <TextBlock Text="Saved Configurations" 
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,10"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Select Network:" 
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,5"/>

                        <ComboBox x:Name="NetworkConfigComboBox"
                                  Height="30"
                                  DisplayMemberPath="Name"
                                  SelectionChanged="NetworkConfigComboBox_SelectionChanged"
                                  ToolTip="Select a saved network configuration"/>

                        <TextBlock Text="Select a configuration to auto-fill credentials" 
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   Foreground="#FF666666"
                                   Margin="0,5,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </GroupBox>

        <!-- Action Section (Connect/Disconnect) -->
        <GroupBox Grid.Row="2" 
                  Header="Action" 
                  Margin="0,0,0,10"
                  Padding="10">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Left">
                <Button Content="Connect" 
                        Click="ConnectButton_Click"
                        Width="100" 
                        Height="30" 
                        Margin="5"/>
                <Button Content="Disconnect" 
                        Click="DisconnectButton_Click"
                        Width="100" 
                        Height="30" 
                        Margin="5"/>
            </StackPanel>
        </GroupBox>

        <TextBlock Grid.Row="3" 
                   x:Name="StatusTextBlock"
                   Text="Ready to connect..." 
                   FontSize="14"
                   Foreground="Blue"
                   Margin="0,0,0,10"/>

        <!-- File Transfer Section -->
        <GroupBox Grid.Row="4" 
                  Header="File Transfer" 
                  Margin="0,0,0,10"
                  Padding="10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Selected File:" 
                               VerticalAlignment="Center" 
                               Margin="0,0,10,0"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="SelectedFileTextBlock"
                               Text="No file selected" 
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Width="400"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Browse File..." 
                            Click="BrowseFileButton_Click"
                            Width="120" 
                            Height="30" 
                            Margin="0,0,10,0"/>
                    <Button x:Name="TransferButton"
                            Content="Transfer File" 
                            Click="TransferFileButton_Click"
                            Width="120" 
                            Height="30"
                            IsEnabled="False"
                            Margin="0,0,10,0"/>
                    <Button x:Name="CancelTransferButton"
                            Content="Cancel Transfer" 
                            Click="CancelTransferButton_Click"
                            Width="120" 
                            Height="30"
                            IsEnabled="False"
                            Background="#FFFF6B6B"
                            Foreground="White"
                            ToolTip="Cancel the current file transfer"/>
                </StackPanel>

                <ProgressBar x:Name="TransferProgressBar"
                             Height="20"
                             Margin="0,10,0,0"
                             Visibility="Collapsed"/>
            </StackPanel>
        </GroupBox>

        <TextBlock Grid.Row="5" 
                   x:Name="ContentTextBlock"
                   Text="" 
                   FontSize="12"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top"/>
    </Grid>
</Page>