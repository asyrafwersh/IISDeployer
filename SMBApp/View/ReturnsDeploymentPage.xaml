<Page x:Class="SMBApp.View.ReturnsDeploymentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SMBApp.View"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1400"
      Title="Returns Deployment">

    <Page.Resources>
        <!-- Style for checklist items -->
        <Style x:Key="ChecklistItem" TargetType="CheckBox">
            <Setter Property="IsEnabled" Value="False"/>
            <Setter Property="Margin" Value="10,2,0,2"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="StepLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ===== PAGE TITLE ===== -->
            <TextBlock Grid.Row="0" 
                       Text="Returns Deployment" 
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <!-- ===== HEADER: Connection Configuration (copied from SMBPage) ===== -->
            <GroupBox Grid.Row="1" 
                      Header="Connection Configuration" 
                      Margin="0,0,0,10"
                      Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Side: Manual Input Fields -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Network Path -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Network Path:" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,10,10"
                                   FontWeight="SemiBold"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 x:Name="NetworkPathTextBox"
                                 Height="25"
                                 Margin="0,0,0,10"
                                 VerticalContentAlignment="Center"/>

                        <!-- Username -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Username:" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,10,10"
                                   FontWeight="SemiBold"/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 x:Name="UsernameTextBox"
                                 Height="25"
                                 Margin="0,0,0,10"
                                 VerticalContentAlignment="Center"/>

                        <!-- Password -->
                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="Password:" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,10,10"
                                   FontWeight="SemiBold"/>
                        <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <PasswordBox Grid.Column="0"
                                         x:Name="PasswordBox"
                                         Height="25"
                                         VerticalContentAlignment="Center"/>
                            <TextBox Grid.Column="0"
                                     x:Name="PasswordTextBox"
                                     Height="25"
                                     VerticalContentAlignment="Center"
                                     Visibility="Collapsed"/>
                            <Button Grid.Column="1"
                                    x:Name="TogglePasswordButton"
                                    Width="30" Height="25"
                                    Margin="5,0,0,0"
                                    Click="TogglePasswordButton_Click"
                                    ToolTip="Show/Hide Password">
                                <TextBlock x:Name="EyeIcon" Text="👁" FontSize="16"/>
                            </Button>
                        </Grid>

                        <!-- Destination Subfolder -->
                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="Dest. Folder:" 
                                   VerticalAlignment="Center" 
                                   Margin="0,0,10,0"
                                   FontWeight="SemiBold"/>
                        <TextBox Grid.Row="3" Grid.Column="1"
                                 x:Name="DestinationSubFolderTextBox"
                                 Height="25"
                                 VerticalContentAlignment="Center"
                                 ToolTip="Subfolder on the remote server (e.g., Downloads)"/>
                    </Grid>

                    <!-- Right Side: Saved Configurations -->
                    <Border Grid.Column="2"
                            Background="#FFFFEB3B"
                            CornerRadius="5"
                            Padding="10"
                            BorderBrush="#FFD4AF37"
                            BorderThickness="2">
                        <StackPanel>
                            <TextBlock Text="Saved Configurations" 
                                       FontWeight="Bold" FontSize="14"
                                       Margin="0,0,0,10"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Select Network:" 
                                       FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox x:Name="NetworkConfigComboBox"
                                      Height="30"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="NetworkConfigComboBox_SelectionChanged"
                                      ToolTip="Select a saved network configuration"/>
                            <TextBlock Text="Select a configuration to auto-fill credentials" 
                                       FontSize="10" TextWrapping="Wrap"
                                       Foreground="#FF666666"
                                       Margin="0,5,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </GroupBox>

            <!-- ===== ACTION SECTION ===== -->
            <GroupBox Grid.Row="2" 
                      Header="Action" 
                      Margin="0,0,0,10"
                      Padding="10">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Connect" Click="ConnectButton_Click"
                                Width="100" Height="30" Margin="5"/>
                        <Button Content="Disconnect" Click="DisconnectButton_Click"
                                Width="100" Height="30" Margin="5"/>
                    </StackPanel>
                    <TextBlock x:Name="StatusTextBlock"
                               Text="Ready..."
                               FontSize="14" Foreground="Blue"
                               Margin="5,5,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- ===== MAIN CONTENT: LEFT/RIGHT SPLIT ===== -->
            <Grid Grid.Row="3" Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===================== LEFT: RETURNS FRONTEND ===================== -->
                <GroupBox Grid.Column="0" Header="Returns Frontend" Padding="10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>

                            <TextBlock Text="Returns Frontend Section" 
                                       FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                            <!-- ===== STEP 1: Select Files and Folders ===== -->
                            <TextBlock Style="{StaticResource StepLabel}" 
                                       Text="1st Step — Select Files and Folders"/>

                            <!-- Parent Source Folder -->
                            <StackPanel Orientation="Horizontal" Margin="10,4,0,4">
                                <TextBlock Text="Parent Source Folder:" 
                                           VerticalAlignment="Center" FontWeight="SemiBold"
                                           Margin="0,0,8,0"/>
                                <TextBlock x:Name="ParentSourceFolderLabel" 
                                           Text="(not set)" 
                                           VerticalAlignment="Center"
                                           Foreground="Gray"
                                           TextTrimming="CharacterEllipsis"
                                           MaxWidth="350"/>
                            </StackPanel>
                            <Button Content="Select Parent Folder" 
                                    Click="SelectParentFolderButton_Click"
                                    Width="160" Height="28" 
                                    HorizontalAlignment="Left" Margin="10,2,0,6"/>

                            <!-- Select Files/Folders -->
                            <Button Content="Select Files / Folders" 
                                    Click="SelectFilesAndFoldersButton_Click"
                                    Width="160" Height="28"
                                    HorizontalAlignment="Left" Margin="10,2,0,6"/>

                            <!-- Selected items panel -->
                            <TextBlock Text="Selected Items:" FontWeight="SemiBold" 
                                       Margin="10,6,0,2"/>
                            <Border BorderBrush="#FFCCCCCC" BorderThickness="1" 
                                    CornerRadius="4" MinHeight="80"
                                    Margin="10,0,0,6" Padding="4">
                                <ItemsControl x:Name="SelectedItemsControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFE8E8E8" CornerRadius="4"
                                                    Margin="3" Padding="6,4">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Icon}" 
                                                               FontSize="14" Margin="0,0,4,0"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Name}" 
                                                               VerticalAlignment="Center"
                                                               MaxWidth="150"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Button Content="✕" 
                                                            Tag="{Binding FullPath}"
                                                            Click="RemoveSelectedItem_Click"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Foreground="Red"
                                                            FontWeight="Bold"
                                                            Margin="6,0,0,0"
                                                            Cursor="Hand"
                                                            ToolTip="Remove"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <!-- Save Settings -->
                            <Button Content="💾 Save Settings" 
                                    Click="SaveSettingsButton_Click"
                                    Width="140" Height="28"
                                    HorizontalAlignment="Left" Margin="10,2,0,10"/>

                            <!-- ===== STEP 2: Zip Files ===== -->
                            <TextBlock Style="{StaticResource StepLabel}" 
                                       Text="2nd Step — Zip Files"/>
                            <StackPanel x:Name="Step2Checklist" Margin="10,0,0,10">
                                <CheckBox x:Name="Chk2_CreateDateFolder" 
                                          Style="{StaticResource ChecklistItem}"
                                          Content="Create date subfolder (DDMMYYYY)"/>
                                <CheckBox x:Name="Chk2_CopyItems" 
                                          Style="{StaticResource ChecklistItem}"
                                          Content="Copy selected items into staging folder"/>
                                <CheckBox x:Name="Chk2_ValidateCopy" 
                                          Style="{StaticResource ChecklistItem}"
                                          Content="Validate copied items exist"/>
                                <CheckBox x:Name="Chk2_ZipFolder" 
                                          Style="{StaticResource ChecklistItem}"
                                          Content="Zip staging folder"/>
                            </StackPanel>

                            <!-- ===== STEP 3: Transfer Zipped File ===== -->
                            <TextBlock Style="{StaticResource StepLabel}" 
                                       Text="3rd Step — Transfer Zipped File to Remote Server"/>
                            <StackPanel x:Name="Step3Checklist" Margin="10,0,0,10">
                                <CheckBox x:Name="Chk3_TransferZip" 
                                          Style="{StaticResource ChecklistItem}"
                                          Content="Transfer zip to remote destination folder"/>
                                <CheckBox x:Name="Chk3_ValidateTransfer" 
                                          Style="{StaticResource ChecklistItem}"
                                          Content="Validate zip exists on remote server"/>
                                <CheckBox x:Name="Chk3_UnzipRemote" 
                                          Style="{StaticResource ChecklistItem}"
                                          Content="Unzip transferred file on remote server"/>
                                <CheckBox x:Name="Chk3_ValidateUnzip" 
                                          Style="{StaticResource ChecklistItem}"
                                          Content="Validate unzipped folder exists"/>
                            </StackPanel>

                            <!-- ===== STEP 4: IIS Stop, Backup, Overwrite, Start ===== -->
                            <TextBlock Style="{StaticResource StepLabel}" 
                                       Text="4th Step — Stop IIS Website, Deploy, Start"/>
                            <StackPanel x:Name="Step4Checklist" Margin="10,0,0,10">
                                <CheckBox x:Name="Chk4_StopIIS" 
                                          Style="{StaticResource ChecklistItem}"
                                          Content="Stop IIS website"/>
                                <CheckBox x:Name="Chk4_BackupEnv" 
                                          Style="{StaticResource ChecklistItem}"
                                          Content="Backup .env file to Backup settings folder"/>
                                <CheckBox x:Name="Chk4_Overwrite" 
                                          Style="{StaticResource ChecklistItem}"
                                          Content="Overwrite website contents with deployment"/>
                                <CheckBox x:Name="Chk4_StartIIS" 
                                          Style="{StaticResource ChecklistItem}"
                                          Content="Start IIS website"/>
                            </StackPanel>

                            <!-- Transfer progress -->
                            <ProgressBar x:Name="FrontendProgressBar"
                                         Height="20" Margin="10,4,0,6"
                                         Visibility="Collapsed"/>

                            <!-- Execute Button -->
                            <Button x:Name="ExecuteFrontendButton"
                                    Content="▶ Execute Deployment" 
                                    Click="ExecuteFrontendButton_Click"
                                    Width="180" Height="35"
                                    HorizontalAlignment="Left" Margin="10,4,0,0"
                                    FontWeight="SemiBold"
                                    Background="#FF4CAF50"
                                    Foreground="White"/>

                        </StackPanel>
                    </ScrollViewer>
                </GroupBox>

                <!-- ===================== RIGHT: RETURNS API ===================== -->
                <GroupBox Grid.Column="2" Header="Returns API" Padding="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="Returns API Section" 
                                   FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="🚧 Coming Soon" FontSize="20"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="This section will have steps similar to the Returns Frontend section.&#x0a;Details will be available in the next prompt."
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   FontSize="12" Foreground="Gray"
                                   MaxWidth="300"/>
                    </StackPanel>
                </GroupBox>

            </Grid>
        </Grid>
    </ScrollViewer>
</Page>