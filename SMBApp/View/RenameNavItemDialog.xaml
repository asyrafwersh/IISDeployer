<Window x:Class="SMBApp.View.RenameNavItemDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Navigation Tab"
        Width="340" Height="140"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="New tab label:" FontWeight="SemiBold" Margin="0,0,0,6"/>

        <TextBox Grid.Row="1" x:Name="LabelTextBox"
                 Height="28" VerticalContentAlignment="Center" Margin="0,0,0,12"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="70" Height="28" Margin="0,0,8,0"
                    IsDefault="True" Click="OkButton_Click"
                    Background="#FF4CAF50" Foreground="White" FontWeight="SemiBold"/>
            <Button Content="Cancel" Width="70" Height="28"
                    IsCancel="True" Click="CancelButton_Click" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>