<Window x:Class="SMBApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SMBApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="900" Width="1440">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Navigation Bar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#FF333333" Height="40">
            <Button Content="SMB Connection" Click="NavSMBPage_Click"
                    Width="140" Margin="5,5" Foreground="White" Background="#FF555555"
                    BorderThickness="0" FontWeight="SemiBold"/>
            <Button Content="Returns Deployment" Click="NavReturnsDeploymentPage_Click"
                    Width="160" Margin="5,5" Foreground="White" Background="#FF555555"
                    BorderThickness="0" FontWeight="SemiBold"/>
        </StackPanel>

        <Frame Grid.Row="1" x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
